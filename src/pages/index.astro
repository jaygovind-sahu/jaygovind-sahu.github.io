---
import Base from "../layouts/Base.astro";
import SectionLabel from "../components/SectionLabel.astro";
import DownloadButton from "../components/DownloadButton.jsx";
import resume from "../data/resume.json";

function formatDate(str: string | null | undefined): string {
  if (!str) return "Present";
  const [year, month] = str.split("-");
  const months = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"];
  return month ? `${months[parseInt(month) - 1]} ${year}` : year;
}

const { meta, experience, education, skills, projects, certifications } = resume;
---

<Base title={`${meta.name} — ${meta.headline}`} description={meta.summary}>
  <main id="main-content" class="max-w-4xl mx-auto px-6 py-16 md:py-24">

    <!-- ── HEADER ──────────────────────────────────────────── -->
    <header class="mb-16">
      <h1 class="font-display text-7xl font-light tracking-tight text-ink mb-4">
        {meta.name}
      </h1>
      <p class="font-display text-2xl font-medium text-accent/80 mb-6">
        {meta.headline}
      </p>
      <p class="font-body text-base leading-relaxed text-ink mb-8">
        {meta.summary}
      </p>

      <!-- Links row -->
      <div class="flex flex-wrap items-center gap-x-5 gap-y-2">
        <a href={`mailto:${meta.email}`} class="link-underline relative font-mono text-xs text-muted hover:text-accent transition-colors">
          {meta.email}
        </a>
        <a href={meta.linkedin} target="_blank" rel="noopener" aria-label="LinkedIn profile" class="link-underline relative font-mono text-xs text-muted hover:text-accent transition-colors">
          LinkedIn ↗
        </a>
        <span class="no-print"><DownloadButton client:idle resume={resume} /></span>
      </div>
    </header>

    <!-- ── EXPERIENCE ──────────────────────────────────────── -->
    <section id="experience" class="fade-up mt-12">
      <SectionLabel label="Experience" />
      <div class="space-y-10">
        {experience.map((exp) => (
          <div class="entry-card">
            <div class="flex items-start justify-between gap-4 mb-1">
              <div>
                <h3 class="font-display text-xl font-medium text-ink">{exp.company}</h3>
                <p class="font-display text-lg text-ink">{exp.title}</p>
              </div>
              <span class="font-mono text-xs text-muted whitespace-nowrap pt-1">
                {formatDate(exp.start)} – {exp.current ? "Present" : formatDate(exp.end)}
              </span>
            </div>
            <ul class="mt-3 space-y-2">
              {exp.bullets.map((bullet) => (
                <li class="flex gap-3 font-body text-base leading-relaxed text-ink">
                  <span class="text-accent mt-1 shrink-0">–</span>
                  <span>{bullet.text}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <!-- ── PROJECTS ────────────────────────────────────────── -->
    <section id="projects" class="fade-up mt-12">
      <SectionLabel label="Side Projects" />
      <div class="space-y-8">
        {projects.map((proj) => (
          <div class="entry-card">
            <div class="flex items-center gap-3 mb-2">
              <h3 class="font-display text-xl font-medium text-ink">{proj.name}</h3>
              {proj.featured && (
                <span class="font-mono text-[9px] tracking-widest text-accent border border-accent rounded px-2 py-0.5 uppercase">
                  Featured
                </span>
              )}
              {proj.url && (
                <a href={proj.url} target="_blank" rel="noopener" class="font-mono text-[11px] text-muted hover:text-accent transition-colors">
                  ↗
                </a>
              )}
            </div>
            <p class="font-body text-base leading-relaxed text-ink mb-3">{proj.description}</p>
            <div class="flex flex-wrap gap-2">
              {proj.tech.map((t) => (
                <span class="font-mono text-[10px] text-muted border border-rule rounded px-2 py-0.5">
                  {t}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- ── SKILLS ──────────────────────────────────────────── -->
    <section id="skills" class="fade-up mt-12">
      <SectionLabel label="Skills" />
      <dl class="space-y-3">
        {skills.map((group) => (
          <div class="flex gap-6">
            <dt class="font-mono text-xs text-muted w-32 shrink-0 pt-0.5">{group.category}</dt>
            <dd class="font-body text-base text-ink leading-relaxed">
              {group.items.join(", ")}
            </dd>
          </div>
        ))}
      </dl>
    </section>

    <!-- ── EDUCATION ───────────────────────────────────────── -->
    <section id="education" class="fade-up mt-12">
      <SectionLabel label="Education" />
      <div class="space-y-6">
        {education.map((edu) => (
          <div class="flex items-start justify-between gap-4">
            <div>
              <h3 class="font-display text-xl font-medium text-ink">{edu.institution}</h3>
              <p class="font-body text-base text-muted">
                {edu.degree} in {edu.field}
                {edu.notes ? ` — ${edu.notes}` : ""}
              </p>
            </div>
            <span class="font-mono text-[11px] text-muted whitespace-nowrap pt-1">{edu.start} – {edu.end}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- ── CERTIFICATIONS ──────────────────────────────────── -->
    <section id="certifications" class="fade-up mt-12">
      <SectionLabel label="Certifications" />
      <div class="space-y-4">
        {certifications.map((cert) => (
          <div class="flex items-start justify-between gap-4">
            <div>
              <p class="font-body text-[15px] text-ink">{cert.name}</p>
              <p class="font-mono text-xs text-muted">{cert.issuer}</p>
            </div>
            <div class="text-right shrink-0">
              <span class="font-mono text-[11px] text-muted block">{formatDate(cert.date)}</span>
              {cert.url && (
                <a href={cert.url} target="_blank" rel="noopener" aria-label={`Verify ${cert.name} on ${cert.issuer}`} class="font-mono text-[10px] text-accent hover:underline">
                  Verify ↗
                </a>
              )}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- ── SCROLL TO TOP ───────────────────────────────────── -->
    <button
      id="back-to-top"
      aria-label="Back to top"
      class="no-print fixed bottom-8 right-8 w-9 h-9 flex items-center justify-center border border-rule rounded bg-paper text-muted hover:text-accent hover:border-accent transition-all opacity-0 pointer-events-none"
    >
      ↑
    </button>

    <!-- ── FOOTER ──────────────────────────────────────────── -->
    <footer class="mt-16 pt-8 border-t border-rule">
      <p class="font-mono text-[10px] text-muted text-center tracking-wide">
        {meta.name} · {meta.website}
      </p>
    </footer>

  </main>
</Base>

<style>
  .entry-card {
    padding: 0.75rem 1rem;
    margin: 0 -1rem;
  }

  .link-underline::after {
    content: "";
    position: absolute;
    bottom: -1px;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--accent);
    transition: width 0.2s ease;
  }
  .link-underline:hover::after {
    width: 100%;
  }
</style>
