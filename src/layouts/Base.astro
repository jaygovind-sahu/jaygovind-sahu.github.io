---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Jaygovind Sahu — Senior Data Engineer",
  description = "Senior Data Engineer with 15+ years of experience building data pipelines and platforms using Python, SQL, Airflow, and AWS.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Jaygovind Sahu" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://jaygovindsahu.com" />

    <title>{title}</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400;1,500&family=DM+Mono:wght@300;400&family=DM+Sans:wght@300;400;500&display=swap"
      rel="stylesheet"
    />

    <style>
      :root {
        --ink: #1a1a18;
        --paper: #f7f6f2;
        --muted: #9a9a94;
        --accent: #c8622a;
        --rule: #e2e0d8;
      }

      html,
      body {
        background-color: var(--paper);
        color: var(--ink);
        font-family: "DM Sans", sans-serif;
        margin: 0;
        padding: 0;
      }

      ::selection {
        background: var(--accent);
        color: var(--paper);
      }

      /* Fade-up animation */
      .fade-up {
        opacity: 0;
        transform: translateY(18px);
        animation: fadeUp 0.6s ease forwards;
      }
      @keyframes fadeUp {
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
      .fade-up:nth-child(1) { animation-delay: 0.05s; }
      .fade-up:nth-child(2) { animation-delay: 0.12s; }
      .fade-up:nth-child(3) { animation-delay: 0.19s; }
      .fade-up:nth-child(4) { animation-delay: 0.26s; }
      .fade-up:nth-child(5) { animation-delay: 0.33s; }
      .fade-up:nth-child(6) { animation-delay: 0.40s; }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
